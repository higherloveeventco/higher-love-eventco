{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "higherloveeventco.com"
        }
      ],
      "destination": "https://www.higherloveeventco.com/:path*",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{"type": "query", "key": "cat"}],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{"type": "query", "key": "p"}],
      "destination": "/",
      "permanent": true
    }
  ]
}
