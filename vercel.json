{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "higherloveeventco.com"
        }
      ],
      "destination": "https://www.higherloveeventco.com/:path*",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{"type": "query", "key": "cat"}],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{"type": "query", "key": "p"}],
      "destination": "/",
      "permanent": true
    },
    { "source": "/book", "destination": "/reserve", "permanent": true },
    { "source": "/book/:path*", "destination": "/reserve", "permanent": true },
    { "source": "/st-johns-weddings", "destination": "/", "permanent": true },
    { "source": "/st-johns-inn", "destination": "/", "permanent": true },
    { "source": "/decor-packages", "destination": "/decor", "permanent": true }
  ]
}
